{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context_monitor.py",
            "timeout": 10,
            "statusMessage": "Checking context budget"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context_monitor.py",
            "timeout": 10,
            "statusMessage": "Checking context budget"
          }
        ]
      }
    ]
  }
}
